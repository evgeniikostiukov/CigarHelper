# Скопируй этот файл в .env и задай реальные значения.
# .env не коммитится в git (см. .gitignore).

# PostgreSQL
POSTGRES_USER=cigarhelper
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cigarhelper

# MinIO
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME_MIN_8_CHARS

# --- Docker Compose, профиль full (см. docs/docker.md) ---
# Секрет JWT для API в контейнере; минимум 32 символа.
JWT_KEY=CHANGE_ME_USE_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# Порт SPA на хосте (CORS под http://localhost:<WEB_PORT>).
WEB_PORT=8080

# Прямой доступ к API на хосте (Kestrel, Swagger).
API_HOST_PORT=5184

# --- Продакшен (docker-compose.production.yml), один сервер, HTTPS снаружи ---
# Список для Host filtering API (через «;»). По умолчанию в примере compose — *.sslip.io и localhost.
# Свой домен: ALLOWED_HOSTS=example.com;www.example.com;*.example.com
# ALLOWED_HOSTS=
# Публичный origin SPA, как в браузере: https://ваш-домен или https://x-x-x-x.sslip.io
# PUBLIC_WEB_ORIGIN=https://example.com
# Тот же порт, что WEB_PORT, если добавляете в CORS прямой http://localhost:<порт> (по умолчанию как WEB_PORT).
# PUBLIC_WEB_PORT=8080

# --- Образы из GHCR (docker-compose.ghcr.example.yml), деплой без сборки на сервере ---
# Владелец пакетов в нижнем регистре, как в ghcr.io/<namespace>/cigarhelper-api
# GHCR_IMAGE_NAMESPACE=your-github-username-or-org
# Тег из GitHub Actions: latest, имя ветки, semver или sha — см. docs/docker.md
# IMAGE_TAG=latest

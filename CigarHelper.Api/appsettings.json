{
  "ForwardedHeaders": {
    "Enabled": false,
    "KnownProxyAddresses": [],
    "ForwardLimit": 1
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=cigar_helper;Username=postgres;Password=CHANGE_ME_IN_USER_SECRETS_OR_ENV"
  },
  "Cors": {
    "PolicyName": "DefaultCors",
    "Origins": [ "http://localhost:3000" ]
  },
  "ImageUpload": {
    "MaxBytes": 5242880
  },
  "ImageStorage": {
    "Provider": "Database",
    "LocalPath": "uploads/images",
    "ThumbnailMaxWidth": 320,
    "ThumbnailMaxHeight": 320
  },
  "Jwt": {
    "Key": "CHANGE_ME_USE_ASPNETCORE_ENVIRONMENT_OR_USER_SECRETS_MIN_32_CHARS",
    "Issuer": "CigarHelperApi",
    "Audience": "CigarHelperClient",
    "AccessTokenDays": 7
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "Properties": {
      "Application": "CigarHelper.Api"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1;[::1]"
}

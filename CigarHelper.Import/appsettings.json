{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=cigarhelper;Username=cigarhelper;Password=CHANGE_ME_IN_USER_SECRETS_OR_ENV"
  },
  "ImageStorage": {
    "Provider": "Minio",
    "LocalPath": "uploads/images",
    "ThumbnailMaxWidth": 320,
    "ThumbnailMaxHeight": 320,
    "Compression": {
      "Original": {
        "Format": "Avif",
        "MaxWidth": 2048,
        "MaxHeight": 2048,
        "AvifCqLevel": 22,
        "WebpQuality": 82,
        "WebpMethod": 4,
        "WebpLossless": false,
        "WebpNearLossless": false,
        "WebpNearLosslessQuality": 60,
        "WebpSkipMetadata": true,
        "PreserveGifAsOriginal": true
      },
      "Thumbnail": {
        "Format": "WebP",
        "MaxWidth": 0,
        "MaxHeight": 0,
        "WebpQuality": 78,
        "WebpMethod": 4,
        "WebpLossless": false,
        "WebpSkipMetadata": true
      }
    },
    "Minio": {
      "Endpoint": "localhost:9000",
      "BucketName": "cigar-images",
      "AccessKey": "CHANGE_ME_IN_USER_SECRETS",
      "SecretKey": "CHANGE_ME_IN_USER_SECRETS",
      "UseSsl": false
    }
  }
}

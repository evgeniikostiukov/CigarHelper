    "typescript-eslint": "^8.57.2",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  }

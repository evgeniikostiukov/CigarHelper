{
  "name": "cigar-helper-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "generate:api": "openapi-typescript ../openapi.json -o src/types/api.generated.ts",
    "generate:spec": "curl -sf http://localhost:5184/swagger/v1/swagger.json -o ../openapi.json && echo OpenAPI spec saved to openapi.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "overrides": {
    "vite-plugin-vue-devtools": {
      "vite-plugin-inspect": "12.0.0-beta.1"
    }
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@tiptap/extension-character-count": "^3.21.0",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@tiptap/vue-3": "^3.21.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "dompurify": "^3.3.3",
    "jwt-decode": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "tailwindcss-primeui": "^0.6.1",
    "zod": "^3.25.0",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@primevue/auto-import-resolver": "^4.5.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.9",
    "openapi-typescript": "^7.13.0",

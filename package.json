{
  "name": "cigar-helper-repo",
  "version": "2.3.1",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "changelog": "auto-changelog"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "auto-changelog": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6"
  },
  "lint-staged": {
    "**/*.cs": [
      "dotnet format CigarHelper.sln --include"
    ],
    "CigarHelper.Web/**/*.{css,html,js,jsx,json,md,scss,ts,tsx,vue,yaml,yml}": [
      "npm --prefix CigarHelper.Web exec -- prettier --write"
    ],
    "CigarHelper.Web/**/*.{js,jsx,ts,tsx,vue}": [
      "npm --prefix CigarHelper.Web exec -- eslint --fix"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@tiptap/extension-character-count": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.3",
    "csv-parser": "^3.2.0",
    "jwt-decode": "^4.0.0",
    "zod": "^4.3.6"
  }
}
